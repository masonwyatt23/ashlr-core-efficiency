{
  "name": "@ashlr/core-efficiency",
  "version": "0.2.0",
  "description": "Token-efficiency primitives for Claude Code: genome, compression, provider-aware budgeting.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./genome": "./src/genome/index.ts",
    "./compression": "./src/compression/index.ts",
    "./budget": "./src/budget/index.ts",
    "./tokens": "./src/tokens/index.ts",
    "./anthropic": "./src/anthropic/index.ts",
    "./session-log": "./src/session-log/index.ts",
    "./local": "./src/local/index.ts"
  },
  "files": [
    "src",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "claude-code",
    "anthropic",
    "mcp",
    "token-efficiency",
    "genome",
    "compression"
  ],
  "engines": {
    "bun": ">=1.0",
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ashlrai/ashlr-core-efficiency.git"
  },
  "bugs": {
    "url": "https://github.com/ashlrai/ashlr-core-efficiency/issues"
  },
  "homepage": "https://github.com/ashlrai/ashlr-core-efficiency#readme",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "bun test",
    "build": "bun build ./src/index.ts --outdir ./dist --target node",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "tiktoken": "^1.0.22"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.40.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    }
  }
}
